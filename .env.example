# APICK — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=1337
NODE_ENV=development
PUBLIC_URL=http://localhost:1337

# =============================================================================
# Database
# =============================================================================
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# PostgreSQL (production)
# DATABASE_CLIENT=postgres
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=apick
# DATABASE_USERNAME=apick
# DATABASE_PASSWORD=
# DATABASE_SSL=false

# =============================================================================
# Auth
# =============================================================================
ADMIN_JWT_SECRET=your-admin-jwt-secret-change-me
API_TOKEN_SALT=your-api-token-salt-change-me
JWT_SECRET=your-jwt-secret-change-me

# =============================================================================
# Queue (for background jobs — AI, webhooks, email, data transfer)
# =============================================================================
QUEUE_DRIVER=memory
# QUEUE_DRIVER=redis
# REDIS_URL=redis://127.0.0.1:6379

# =============================================================================
# AI Providers — configure whichever you use
# =============================================================================

# OpenAI (for @apick/provider-ai-openai)
OPENAI_API_KEY=sk-proj-your-openai-api-key
# OPENAI_ORG=org-optional

# Anthropic (for @apick/provider-ai-anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google AI / Gemini (for @apick/provider-ai-google)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Ollama (for @apick/provider-ai-ollama — local, no key needed)
OLLAMA_URL=http://localhost:11434

# OpenRouter (alternative: use as OpenAI-compatible endpoint)
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# External Services (for plugins/testing)
# =============================================================================

# Firecrawl (web crawling)
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key

# Tavily (search)
TAVILY_API_KEY=tvly-your-tavily-api-key

# Serper (search)
SERPER_API_KEY=your-serper-api-key

# Unstructured (document parsing)
UNSTRUCTURED_API_KEY=your-unstructured-api-key
