{
  "name": "@apick/utils",
  "version": "0.3.0",
  "description": "Error classes, env helpers, UID utilities, and object/string utils for APICK headless CMS",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/vivmagarwal/apickjs/tree/main/packages/utils",
  "repository": { "type": "git", "url": "git+https://github.com/vivmagarwal/apickjs.git", "directory": "packages/utils" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist/"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
