{
  "name": "@apick/core",
  "version": "0.2.0",
  "description": "Framework kernel for APICK — a pure headless CMS built TypeScript-first with no admin UI",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/vivmagarwal/apickjs/tree/main/packages/core",
  "repository": { "type": "git", "url": "git+https://github.com/vivmagarwal/apickjs.git", "directory": "packages/core" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist/"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@apick/types": "0.2.0",
    "@apick/utils": "0.2.0",
    "find-my-way": "^9.2.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "secure-json-parse": "^3.0.1",
    "dotenv": "^16.4.0",
    "zod": "^3.24.0",
    "drizzle-orm": "^0.38.0",
    "better-sqlite3": "^11.8.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}
