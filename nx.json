{
  "namedInputs": {
    "default": ["{projectRoot}/**/*"],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/__tests__/**",
      "!{projectRoot}/**/*.md"
    ]
  },
  "targetDefaults": {
    "build": {
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "inputs": ["default"],
      "cache": true
    },
    "test:unit": {
      "inputs": ["default"],
      "cache": true
    },
    "clean": {
      "cache": false
    }
  }
}
